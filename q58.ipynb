    "class Employee:\n",
    "    count = 0\n",
    "\n",
    "    def __init__(self, name):\n",
    "        self.name = name\n",
    "        Employee.count += 1\n",
    "\n",
    "    @classmethod\n",
    "    def get_employee_count(cls):\n",
    "        return cls.count\n",
    "\n",
    "e1 = Employee(\"A\")\n",
    "e2 = Employee(\"B\")\n",
    "e3 = Employee(\"C\")\n",
    "\n",
    "print(Employee.get_employee_count())"
   ]
  }
