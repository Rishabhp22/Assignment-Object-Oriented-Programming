    "class Circle:\n",
    "    def __init__(self, radius):\n",
    "        self.radius = radius\n",
    "\n",
    "    def calculate_area(self):\n",
    "        return 22/7 * self.radius**2\n",
    "\n",
    "c = Circle(5)\n",
    "c.calculate_area()"
