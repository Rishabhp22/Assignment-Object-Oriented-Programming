   "outputs": [],
   "source": [
    "class Mydecorator:\n",
    "    def __init__(self, func):\n",
    "        self.func = func\n",
    "\n",
    "    def __call__(self):\n",
    "        print(\"Hello Sir!\")\n",
    "        self.func()\n",
    "        print(\"Bye Sir!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "264736f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "@Mydecorator\n",
    "def name():\n",
    "    print(\"Rishabh Poddar\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "39c09466",
   "metadata": {},
