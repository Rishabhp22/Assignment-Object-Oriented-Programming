   "source": [
    "def prime_gen(n):\n",
    "    for num in range(2,n+1):\n",
    "        is_prime = True\n",
    "\n",
    "        for i in range(2, num):\n",
    "            if num %i == 0:\n",
    "                is_prime = False\n",
    "                break\n",
    "\n",
    "        if is_prime:\n",
    "            yield num\n",
    "\n",
    "\n",
    "for p in prime_gen(40):\n",
    "    print(p)"
   ]
  }
