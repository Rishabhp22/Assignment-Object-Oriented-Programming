    "\n",
    "    @staticmethod\n",
    "    def celsius_to_fahrenheit(c):\n",
    "        return f\"{(c * 9/5) + 32}F\"\n",
    "\n",
    "print(TemperatureConverter.celsius_to_fahrenheit(25))"
