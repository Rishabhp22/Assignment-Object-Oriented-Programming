   "source": [
    "def even_nums(nums):\n",
    "    for num in nums:\n",
    "        if num%2==0:\n",
    "            yield num**2\n",
    "\n",
    "\n",
    "for num in even_nums([1,2,3,5,6]):\n",
    "    print(num)"
   ]
  },
